# Base de datos (el contenedor de docker-compose expone el puerto 5435 en el host)
DATABASE_URL="postgresql://salesflow:salesflow@localhost:5435/salesflow?schema=public"

# JWT
JWT_SECRET="cambiar_en_produccion_min_32_chars_aaaaaa"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="cambiar_en_produccion_min_32_chars_bbbbbb"
JWT_REFRESH_EXPIRES_IN="7d"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# App
PORT=3000
NODE_ENV="development"
FRONTEND_URL="http://localhost:4200"
COOKIE_DOMAIN="localhost"

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
