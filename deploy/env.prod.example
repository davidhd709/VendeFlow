# ─────────────────────────────────────────────────────────────────────────────
# VentasFlow — Variables de entorno de producción
# Copiar a .env.prod en el servidor y rellenar los valores reales.
# NUNCA subir .env.prod a git.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=ventasflow
POSTGRES_PASSWORD=CAMBIAR_POR_PASSWORD_SEGURA
POSTGRES_DB=ventasflow_prod

# URL que usa Prisma (coincide con los campos de arriba)
DATABASE_URL=postgresql://ventasflow:CAMBIAR_POR_PASSWORD_SEGURA@postgres:5432/ventasflow_prod

# ── Autenticación JWT ─────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_STRING_ALEATORIO_64_BYTES
JWT_REFRESH_SECRET=CAMBIAR_POR_OTRO_STRING_ALEATORIO_64_BYTES

# Expiración de tokens
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Cookies (refresh token) ───────────────────────────────────────────────────
# Dominio raíz para que la cookie funcione en subdominos (p.ej. .tudominio.com)
# Dejar vacío si no usas subdominos
COOKIE_DOMAIN=

# ── URLs ──────────────────────────────────────────────────────────────────────
# URL pública del frontend (sin barra final)
FRONTEND_URL=https://tudominio.com

# ── Aplicación ────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Cloudinary (almacenamiento de imágenes) ───────────────────────────────────
# Obtener en: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=CAMBIAR
CLOUDINARY_API_KEY=CAMBIAR
CLOUDINARY_API_SECRET=CAMBIAR

# ── Email (opcional — para notificaciones futuras) ───────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=CAMBIAR
# SMTP_FROM="VentasFlow <noreply@tudominio.com>"
